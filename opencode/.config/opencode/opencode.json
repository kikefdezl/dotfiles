{
       "$schema": "https://opencode.ai/config.json",
       "permission": {
              "bash": {
                     "git commit": "ask",
                     "git commit *": "ask",
                     "terraform apply": "deny",
                     "terraform apply *": "deny",
                     "tf apply": "deny",
                     "tf apply *": "deny",
                     "gcloud": "ask",
                     "gcloud *": "ask"
              }
       },
       "provider": {
              "google-vertex": {
                     "options": {
                            "headers": {
                                   "X-Vertex-AI-LLM-Request-Type": "shared",
                                   "X-Vertex-AI-LLM-Shared-Request-Type": "priority"
                            }
                     }
              }
       }
}

