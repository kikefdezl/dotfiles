{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "bash": {
      "git commit": "deny",
      "git commit *": "deny",
      "git add": "deny",
      "git add *": "deny",
      "terraform apply": "deny",
      "terraform apply *": "deny",
      "tf apply": "deny",
      "tf apply *": "deny",
      "gcloud": "deny",
      "gcloud *": "deny"
    }
  },
  "plugin": [
    "/home/kike/Dev/ponytail/.opencode/plugins/ponytail.mjs",
    "@mohak34/opencode-notifier@latest"
  ],
  "mcp": {
    "open-design": {
      "type": "local",
      "command": [
        "/usr/bin/node",
        "/usr/lib/open-design/apps/daemon/dist/cli.js",
        "mcp",
        "--daemon-url",
        "http://127.0.0.1:7456"
      ],
      "enabled": false,
      "environment": {
        "OD_DATA_DIR": "/home/kike/.local/share/open-design"
      }
    }
  }
}
